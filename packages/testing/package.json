{
  "name": "@motus/testing",
  "version": "1.0.0",
  "description": "Shared testing utilities, fixtures, and helpers for Motus",
  "author": "Mohit Gupta <bhrji.4438@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhrji4438/motus.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@motus/types": "*",
    "@motus/core": "*",
    "ioredis": "^5.3.2",
    "socket.io-client": "^4.7.5",
    "testcontainers": "^10.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
