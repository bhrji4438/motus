{
  "name": "@motus/types",
  "version": "1.0.0",
  "description": "Shared API contracts, types, and governance definitions for Motus",
  "author": "Mohit Gupta <bhrji.4438@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhrji4438/motus.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsup": "^8.0.2",
    "rimraf": "^5.0.7"
  }
}
